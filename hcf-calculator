import math

num1 = int(input("Enter number 1: "))
num2 = int(input("Enter number 2: "))
list1 = []
list2 = []

for n in range(1, num1 + 1):
    if num1 % n == 0:
        list1.append(n)
        
for m in range(1, num2 + 1):
    if num2 % m == 0:
        list2.append(m)
        
common_factors = [factor for factor in list1 if factor in list2]

print(f"The common factors of {num1} and {num2} are: ")
for factor in common_factors:
    print(factor)

# The HCF is simply the largest number in the common factors list
hcf = max(common_factors)
print(f"The HCF of {num1} and {num2} is: {hcf}")

# To multiply all common factors together
product_of_factors = math.prod(common_factors)
print(f"The product of all common factors is: {product_of_factors}")
